# LiveKit Cloud project (required for /api/token and client connect)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# WebSocket URL for the browser (must be set for the client to connect)
# Get this from your LiveKit Cloud project dashboard, e.g. wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=

# Optional: agent name to dispatch to the room (default: CA_aGnmHJiQijRD)
# LIVEKIT_AGENT_NAME=CA_aGnmHJiQijRD

# Mapbox public token for 3D map (pk.xxx from mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=
